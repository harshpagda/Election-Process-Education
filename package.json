{
  "name": "election-process-assistant",
  "version": "1.0.0",
  "description": "AI-powered Election Process Assistant - Hackathon & Production Ready",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspaces",
    "install-all": "npm install && npm install --workspace=backend && npm install --workspace=frontend",
    "test": "npm test --workspaces",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "election",
    "assistant",
    "ai",
    "mern",
    "react",
    "nodejs"
  ],
  "author": "Harsh Pagda",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}